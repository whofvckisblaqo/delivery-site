generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Order {
  id            Int      @id @default(autoincrement())
  orderId       String   @unique
  customer      String
  phone         String?
  fromLocation  String
  toLocation    String
  service       String
  status        String   @default("Pending")
  amount        String
  date          String
  customerEmail String?
  description   String?  @db.Text
  createdAt     DateTime @default(now())
}

model Customer {
  id         Int      @id @default(autoincrement())
  customerId String   @unique
  name       String
  email      String   @unique
  phone      String?
  city       String?
  orders     Int      @default(0)
  spent      String   @default("$0.00")
  joined     String
  status     String   @default("Active")
  createdAt  DateTime @default(now())
}

model Tracking {
  id            Int      @id @default(autoincrement())
  orderId       String   @unique
  customer      String
  customerEmail String?
  fromLocation  String
  toLocation    String
  status        String   @default("Pending")
  estimate      String?
  driver        String?
  steps         Json
  createdAt     DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  messageId String   @unique
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  time      String
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}